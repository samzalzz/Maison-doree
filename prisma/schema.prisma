// ---------------------------------------------------------------------------
// WORKFLOW SYSTEM  (Phase 3)
// ---------------------------------------------------------------------------

// How a Workflow is triggered.
// MANUAL      – explicit admin invocation (Phase 3 default)
// SCHEDULED   – cron-based execution (Phase 4)
// EVENT_BASED – triggered by a system event, e.g. low stock (Phase 4)
enum WorkflowTriggerType {
  MANUAL
  SCHEDULED
  EVENT_BASED
}

// The kind of node a WorkflowStep represents.
// ACTION    – executes a side-effect (transfer, notify, email, …)
// CONDITION – evaluates WorkflowConditions and branches
enum WorkflowStepType {
  ACTION
  CONDITION
}

// Comparison operator inside a WorkflowCondition.
enum WorkflowConditionOperator {
  EQUALS
  GREATER_THAN
  LESS_THAN
  CONTAINS
}

// Lifecycle status of a WorkflowAction execution record.
enum WorkflowActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// 23. Workflow — a named automation rule created by an admin
model Workflow {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Whether this workflow is available for execution
  isActive Boolean @default(true)

  // Trigger mechanism; defaults to MANUAL for Phase 3
  triggerType WorkflowTriggerType @default(MANUAL)

  // Ordered execution nodes
  steps WorkflowStep[]

  // Execution history records
  actions WorkflowAction[]

  // Admin user ID — plain TEXT, no FK (User model out of scope for workflow)
  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// 24. WorkflowStep — one ordered node within a workflow
model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 1-based execution order; unique per workflow
  stepNumber Int

  // ACTION executes a side-effect; CONDITION evaluates guards
  type WorkflowStepType

  // Identifies the concrete handler, e.g. "TRANSFER", "UPDATE_INVENTORY",
  // "NOTIFY", "EMAIL". NULL for CONDITION steps.
  actionType String?

  // Flexible JSON config for the action handler, e.g.:
  //   { sourceLabId: "…", destLabId: "…", materialId: "…", quantity: 100 }
  // NULL for CONDITION steps.
  actionPayload Json?

  // Mirrors stepNumber for API ergonomics
  order Int

  // Condition guards (only populated for CONDITION steps)
  conditions WorkflowCondition[]

  // Execution history records for this step
  actions WorkflowAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowId, stepNumber])
  @@index([workflowId])
  @@index([workflowId, stepNumber])
}

// 25. WorkflowCondition — a boolean guard attached to a CONDITION step
// Multiple conditions on one step are OR'd; across steps they are AND'd.
model WorkflowCondition {
  id     String       @id @default(cuid())
  stepId String
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  // Field path to evaluate, e.g. "labStock.quantity", "materialId"
  field String

  // Comparison operator applied between field and value
  operator WorkflowConditionOperator

  // Comparison value stored as string; parsed at runtime
  value String

  createdAt DateTime @default(now())

  @@index([stepId])
}

// 26. WorkflowAction — execution history record for one step run
// This is an AUDIT TABLE, not a step template.  One row is created per
// step execution and captures its outcome.
model WorkflowAction {
  id String @id @default(cuid())

  // Denormalised workflowId for efficient per-workflow history queries
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  stepId String
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  // Execution lifecycle
  status WorkflowActionStatus @default(PENDING)

  // Timestamp when the action reached COMPLETED or FAILED
  executedAt DateTime?

  // Result payload, e.g.:
  //   { "transferredQuantity": 100, "sourceStock": 50, "destStock": 250 }
  result Json?

  // Human-readable error when status = FAILED
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([stepId])
  @@index([status])
  @@index([workflowId, status])
}

// ============================================================================
// PHASE 1 SAP: RECIPE DEVELOPMENT (RD)
// ============================================================================

// RD-1. RecipeVersion — a versioned snapshot of a recipe with cost tracking
model RecipeVersion {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  versionNumber Int
  versionName   String?
  description   String?
  laborMinutes  Int

  estimatedCost  Decimal?  @db.Decimal(12, 2)
  lastCostUpdate DateTime?
  isActive       Boolean   @default(true)
  deprecatedAt   DateTime?

  // Self-referential: points to the version this one was branched from
  previousVersionId String?
  previousVersion   RecipeVersion?  @relation("VersionHistory", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions      RecipeVersion[] @relation("VersionHistory")

  // Relations
  changes     RecipeVersionHistory[]
  ingredients RecipeVersionIngredient[]

  createdBy String // admin user ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recipeId, versionNumber])
  @@index([recipeId])
  @@index([isActive])
  @@index([createdAt])
}

// RD-2. RecipeVersionIngredient — an ingredient line inside a recipe version
model RecipeVersionIngredient {
  id              String        @id @default(cuid())
  recipeVersionId String
  recipeVersion   RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade)

  rawMaterialId String?
  rawMaterial   RawMaterial? @relation("RawMaterialVersion", fields: [rawMaterialId], references: [id], onDelete: SetNull)

  intermediateId String?
  intermediate   RawMaterial? @relation("IntermediateVersionUsage", fields: [intermediateId], references: [id], onDelete: SetNull)

  quantity    Decimal  @db.Decimal(10, 2)
  unit        String
  costPerUnit Decimal? @db.Decimal(12, 4)
  totalCost   Decimal? @db.Decimal(12, 2)
  notes       String?

  @@index([recipeVersionId])
}

// RD-3. RecipeVersionHistory — an audit log entry recording a field change on a recipe version
model RecipeVersionHistory {
  id              String        @id @default(cuid())
  recipeVersionId String
  recipeVersion   RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade)

  changeType String // e.g. "INGREDIENT_ADDED" | "COST_UPDATED" | "STATUS_CHANGED"
  fieldName  String?
  oldValue   String?
  newValue   String?

  changedBy  String // admin user ID
  changeDate DateTime @default(now())
  reason     String?

  @@index([recipeVersionId])
  @@index([changeDate])
}

enum MRPSuggestionStatus {
  PENDING
  ORDERED
  COMPLETED
  DISMISSED
}

enum TraceabilityEventType {
  MATERIAL_ALLOCATED
  PRODUCTION_STARTED
  PRODUCTION_COMPLETED
  SHIPPED
  RECALL
}

// ============================================================================
// PHASE 1 SAP: PRODUCTION PLANNING (PP) & TRACEABILITY
// ============================================================================

// PP-1. EnhancedForecast — ML-assisted demand forecast per recipe per day
model EnhancedForecast {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  recipeId String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  predictedQuantity Int
  confidenceLevel   Int // 0-100

  sevenDayAvg      Decimal? @db.Decimal(10, 2)
  thirtyDayAvg     Decimal? @db.Decimal(10, 2)
  seasonalFactor   Decimal? @db.Decimal(10, 4)
  dayOfWeekPattern Decimal? @db.Decimal(10, 4)

  mlPrediction Int?
  mlConfidence Int?

  // SIMPLE_AVERAGE | SEASONAL | HYBRID_RULES_ML
  algorithm String
  reasoning String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, recipeId])
  @@index([date])
  @@index([recipeId])
}

// PP-2. MRPSuggestion — a material requirements planning reorder recommendation
model MRPSuggestion {
  id         String      @id @default(cuid())
  materialId String
  material   RawMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  currentStock   Decimal  @db.Decimal(10, 2)
  minThreshold   Decimal  @db.Decimal(10, 2)
  maxCapacity    Decimal? @db.Decimal(10, 2)
  projectedUsage Decimal  @db.Decimal(10, 2)
  projectedDate  DateTime
  recommendedQty Decimal  @db.Decimal(10, 2)

  // PENDING | ORDERED | COMPLETED | DISMISSED
  status        MRPSuggestionStatus
  createdAt     DateTime            @default(now())
  dismissedAt   DateTime?
  dismissReason String?

  @@index([materialId])
  @@index([status])
  @@index([projectedDate])
  @@index([supplierId])
}

// PP-3. MaterialAllocation — links a raw material to a production batch with quantities
model MaterialAllocation {
  id         String          @id @default(cuid())
  batchId    String
  batch      ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  materialId String
  material   RawMaterial     @relation(fields: [materialId], references: [id], onDelete: Cascade)

  allocatedQty Decimal  @db.Decimal(10, 2)
  actualQty    Decimal? @db.Decimal(10, 2)
  allocatedAt  DateTime @default(now())

  @@unique([batchId, materialId])
  @@index([batchId])
}

// TR-1. TraceabilityRecord — immutable event log for batch genealogy and recall tracking
model TraceabilityRecord {
  id      String          @id @default(cuid())
  batchId String
  batch   ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // MATERIAL_ALLOCATED | PRODUCTION_STARTED | PRODUCTION_COMPLETED | SHIPPED | RECALL
  event      TraceabilityEventType
  details    String
  location   String?
  timestamp  DateTime              @default(now())
  recordedBy String // admin user ID

  @@index([batchId])
  @@index([timestamp])
}
