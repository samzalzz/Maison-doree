  supplierId      String
  supplier        Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  suggestedQty    Decimal     @db.Decimal(10, 2)
  reasoning       String

  status          String      @default("PENDING")

  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

